# Database
DATABASE_URL="postgresql://stockalert:stockalert@localhost:5432/stockalert"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT (shared with frontend)
JWT_SECRET="your-jwt-secret-min-32-chars-change-this"

# NextAuth (frontend uses this separately)
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Backend port
PORT=3001

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Polygon.io (US stocks)
POLYGON_API_KEY="your-polygon-api-key"

# 한국투자증권 API (Korean stocks)
KIS_APP_KEY="your-kis-app-key"
KIS_APP_SECRET="your-kis-app-secret"
KIS_ACCOUNT_NO="your-account-number"

# VAPID (Web Push)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@example.com"

# Slack (optional: batch failure alerts)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
